# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ProposalRoom
DEMO_MODE=true

# Database / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth session (demo local JWT)
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# AI providers (Vercel AI SDK adapters)
OPENAI_API_KEY=
XAI_API_KEY=
AI_PROVIDER=mock

# Billing
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=

# Email
EMAIL_PROVIDER=mock
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ProposalRoom <noreply@proposalroom.app>

# Observability / Analytics
SENTRY_DSN=
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
