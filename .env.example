# App / Lab
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ProposalRoom
# Keep true for portfolio lab (mock billing). Set false only with real secrets + persistence.
DEMO_MODE=true

# Persistence — SQLite file by default (survives local restarts). Optional Turso for multi-instance.
# SQLITE_PATH=.data/proposalroom.db
# SQLITE_URL=:memory:
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Database / Supabase (optional future path — schema in /supabase; lab uses SQLite/libsql)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth session (JWT) — required ≥32 chars in non-demo production
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# AI providers (lab uses local section generator; set mock unless wiring SDKs)
OPENAI_API_KEY=
XAI_API_KEY=
AI_PROVIDER=mock

# Billing — keep mock for lab; never commit live secrets
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=

# Email
EMAIL_PROVIDER=mock
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ProposalRoom <noreply@proposalroom.app>

# Observability / Analytics (optional)
SENTRY_DSN=
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
